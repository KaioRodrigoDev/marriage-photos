// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Person {
  id            String       @id @default(cuid())
  name          String       @unique
  createdAt     DateTime     @default(now())
  gifts         PhotoGift[]   @relation("GiftSender")
  taggedIn      PhotoTag[]
}

model PhotoGift {
  id           String      @id @default(cuid())
  senderId     String
  sender       Person      @relation("GiftSender", fields: [senderId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  url          String
  storageTarget String    @default("oracle")
  mimeType     String
  size         Int
  message      String?
  createdAt    DateTime    @default(now())
  tags         PhotoTag[]
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PixGeneration {
  id            String   @id @default(cuid())
  senderName    String?
  amount        Int
  transactionId String   @unique
  payload       String
  createdAt     DateTime @default(now())
}

model PhotoTag {
  id        String    @id @default(cuid())
  photoId   String
  personId  String
  photo     PhotoGift @relation(fields: [photoId], references: [id], onDelete: Cascade)
  person    Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([photoId, personId])
}
